# OpenCode Go / Zen API (https://opencode.ai/auth)
# Replace with your own key. NEVER commit the real .env file.
OPENCODE_API_KEY=replace-me

# Vision endpoint (Zen Responses API for GPT-5.x models)
OPENCODE_VISION_BASE_URL=https://opencode.ai/zen/v1
VISION_MODEL=gpt-5.4-nano
VISION_MAX_FRAMES_PER_CLIP=6

# Text endpoint (Go subscription, chat/completions for open coding models)
OPENCODE_TEXT_BASE_URL=https://opencode.ai/zen/go/v1
TEXT_MODEL=glm-5.2

# FFmpeg binaries (optional; defaults to PATH)
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
# FFPROBE_PATH=C:\path\to\ffprobe.exe

# Directories
INPUT_DIR=./input
OUTPUT_DIR=./output
MUSIC_DIR=./assets/music
TEMP_DIR=./.tmp

# Reel constraints
MAX_DURATION_SEC=60
MIN_SEGMENT_SEC=1.2
MAX_SEGMENT_SEC=6
CROSSFADE_SEC=0.3
TARGET_LUFS=-14
LOG_LEVEL=info
